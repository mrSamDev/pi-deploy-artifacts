{
  "name": "@mrsamdev/pi-artifacts",
  "version": "0.1.0",
  "description": "Deploy HTML artifacts to Vercel, Cloudflare Pages, Netlify, or GitHub Pages — like Claude Code artifacts for pi",
  "keywords": [
    "pi-package",
    "artifacts",
    "deploy",
    "vercel",
    "cloudflare",
    "netlify",
    "github-pages"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/",
    "skills/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrSamDev/pi-artifacts.git"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc --noEmit && tsdown",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "test:integration": "vitest run --project integration",
    "test:all": "vitest run"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.10",
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.9",
    "typebox": "^1.3.6",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills"
    ]
  }
}
